<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="600.0" prefWidth="400.0"
            style="-fx-background-color: #ffffff;"
            xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="SpeedyProject.Controllers.TrackingController">
   <children>
      <ImageView fitHeight="98.0" fitWidth="77.0"
                 layoutX="14.0" layoutY="14.0"
                 pickOnBounds="true" preserveRatio="true"
                 onMouseClicked="#goToPrincipalMenu" style="-fx-cursor: hand;">
         <image>
            <Image url="@../images/logo.png" />
         </image>
      </ImageView>
      <ImageView fitHeight="40.0" fitWidth="41.0" layoutX="218.0" layoutY="30.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../images/userLogo.png" />
         </image>
      </ImageView>
      <Label fx:id="lblUserName" layoutX="269.0" layoutY="30.0" prefHeight="34.0" prefWidth="117.0" text="" wrapText="true">
         <font>
            <Font name="Arial Bold" size="12.0" />
         </font>
      </Label>
      <Separator layoutX="-12.0" layoutY="85.0" opacity="0.5" prefHeight="30.0" prefWidth="414.0" />

      <Label layoutX="34.0" layoutY="105.0" text="Seguimiento" textFill="#222222">
         <font>
            <Font name="Arial Bold" size="24.0" />
         </font>
      </Label>
      <Label layoutX="34.0" layoutY="135.0" prefWidth="333.0" text="Pedidos actualmente en curso" textFill="#666666">
         <font>
            <Font name="Arial" size="13.0" />
         </font>
      </Label>

      <Label fx:id="lblEmptyTracking" layoutX="34.0" layoutY="240.0" prefWidth="333.0" text="No tienes pedidos en curso en este momento"
             textAlignment="CENTER" wrapText="true" textFill="#999999" visible="false">
         <font>
            <Font name="Arial" size="13.0" />
         </font>
      </Label>

      <ScrollPane layoutX="34.0" layoutY="170.0" prefWidth="333.0" prefHeight="185.0" fitToWidth="true"
                  style="-fx-background-color: transparent; -fx-background: transparent;">
         <content>
            <VBox fx:id="activeOrdersContainer" spacing="10.0" prefWidth="325.0" />
         </content>
      </ScrollPane>

      <VBox fx:id="progressSection" layoutX="34.0" layoutY="368.0" prefWidth="333.0" spacing="10.0"
            style="-fx-background-color: #fcfcfc; -fx-border-color: #eeeeee; -fx-border-radius: 12; -fx-background-radius: 12;">
         <padding>
            <javafx.geometry.Insets bottom="14.0" left="16.0" right="16.0" top="14.0" />
         </padding>
         <children>
            <Label fx:id="lblSelectedOrder" text="Pedido #0" textFill="#333333">
               <font>
                  <Font name="Arial Bold" size="16.0" />
               </font>
            </Label>
            <Label fx:id="lblSelectedStatus" text="Preparando" textFill="#F26513">
               <font>
                  <Font name="Arial Bold" size="13.0" />
               </font>
            </Label>
            <ProgressBar fx:id="progressBar" prefWidth="300.0" progress="0.0" style="-fx-accent: #F26513;" />
            <Button fx:id="btnAdvance" mnemonicParsing="false" onAction="#onAdvanceOrder" prefHeight="34.0" prefWidth="300.0"
                    style="-fx-background-color: #F26513; -fx-background-radius: 18; -fx-cursor: hand;"
                    text="Simular avance del pedido" textFill="WHITE">
               <font>
                  <Font name="Arial Bold" size="12.0" />
               </font>
            </Button>
         </children>
      </VBox>

      <Pane layoutY="535.0" prefHeight="65.0" prefWidth="400.0" style="-fx-background-color: #F26513;">
         <children>
            <HBox alignment="CENTER" prefHeight="65.0" prefWidth="400.0">
               <children>
                  <Label text="Atención al cliente: 772-345(1) opción 2" textFill="WHITE">
                     <font>
                        <Font name="Arial" size="12.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
         </children>
      </Pane>
   </children>
</AnchorPane>
